}

spawn ssh -p $port -o StrictHostKeyChecking=no $user@$host
expect {
    "password:" {
        send "$password\r"
        exp_continue
    }
    "$ " {
        send "mysql -u $db_user -p'$db_pass' $db_name < force_admin_role.sql\r"
        expect "$ "
        send "rm force_admin_role.sql\r"
        send "exit\r"
    }
}
