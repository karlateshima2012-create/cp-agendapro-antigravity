#!/usr/bin/expect -f
set timeout 120
set port 65002
set user "u176367625"
set host "46.202.186.144"
set password "23KDHkt10cp$"
set remote_path "domains/creativeprintjp.com/public_html/cpagendapro"
set local_script "scripts/check_column.php"

# 1. Upload test script
spawn scp -P $port -o StrictHostKeyChecking=no $local_script $user@$host:$remote_path/check_column.php
expect {
    "password:" {
        send "$password\r"
        exp_continue
    }
    eof
}

# 2. Run it
spawn ssh -p $port -o StrictHostKeyChecking=no $user@$host
expect {
    "password:" {
        send "$password\r"
        exp_continue
    }
    "$ " {
        send "cd $remote_path && php check_column.php\r"
        expect "$ "
        
        # Cleanup
        send "rm check_column.php\r"
        expect "$ "
        
        send "exit\r"
    }
}
expect eof
