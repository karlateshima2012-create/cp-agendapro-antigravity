#!/usr/bin/expect -f

set timeout 20
set password "23KDHkt10cp$"
set user "u176367625"
set host "46.202.186.144"
set port "65002"
set cookie_file "cookie_bd.txt"

spawn ssh -p $port -o StrictHostKeyChecking=no $user@$host
expect {
    "password:" {
        send "$password\r"
        exp_continue
    }
    "$ " {
        # 1. Login
        send "curl -c $cookie_file -X POST -H 'Content-Type: application/json' -d '{\"email\":\"suporte@creativeprintjp.com\",\"password\":\"password1234\"}' https://cpagendapro.creativeprintjp.com/api/auth/login\r"
        expect "$ "

        # 2. Save Availability with Blocked Date (Use escaped quotes for inner JSON)
        send "curl -b $cookie_file -X PUT -H 'Content-Type: application/json' -d '{\"workingHours\":\[\],\"intervalMinutes\":30,\"blockedDates\":\[{\"date\":\"2026-12-25\",\"reason\":\"Natal Teste\"}\]}' https://cpagendapro.creativeprintjp.com/api/availability\r"
        expect "$ "

        # 3. Get Availability to verify
        send "curl -b $cookie_file https://cpagendapro.creativeprintjp.com/api/availability\r"
        expect "$ "
        
        send "rm $cookie_file\r"
        send "exit\r"
    }
}
expect eof
