#!/usr/bin/expect -f
set timeout 120
set port 65002
set user "u176367625"
set host "46.202.186.144"
set password "23KDHkt10cp$"
set remote_path "domains/creativeprintjp.com/public_html/cpagendapro"
set local_script "scripts/test_admin_order_db.php"

spawn scp -P $port -o StrictHostKeyChecking=no $local_script $user@$host:$remote_path/test_admin_order_db.php
expect {
    "password:" {
        send "$password\r"
        exp_continue
    }
    eof
}

spawn ssh -p $port -o StrictHostKeyChecking=no $user@$host
expect {
    "password:" {
        send "$password\r"
        exp_continue
    }
    "$ " {
        send "cd $remote_path && php test_admin_order_db.php\r"
        expect "$ "
        send "rm test_admin_order_db.php\r"
        expect "$ "
        send "exit\r"
    }
}
expect eof
