#!/usr/bin/expect -f

set timeout 20
set password "23KDHkt10cp$"
set user "u176367625"
set host "46.202.186.144"
set port "65002"
set local_script "scripts/diagnose_images_remote.php"
set remote_script "domains/creativeprintjp.com/public_html/cpagendapro/diagnose_images_remote.php"
set run_path "domains/creativeprintjp.com/public_html/cpagendapro"

# 1. SCP the file
spawn scp -P $port -o StrictHostKeyChecking=no $local_script $user@$host:$remote_script
expect {
    "password:" {
        send "$password\r"
        exp_continue
    }
    eof
}

# 2. SSH to run it
spawn ssh -p $port -o StrictHostKeyChecking=no $user@$host
expect {
    "password:" {
        send "$password\r"
        exp_continue
    }
    "$ " {
        send "cd $run_path && php diagnose_images_remote.php\r"
        expect "$ "
        
        # Cleanup
        send "rm diagnose_images_remote.php\r"
        expect "$ "
        
        send "exit\r"
    }
}
expect eof
