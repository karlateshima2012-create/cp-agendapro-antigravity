# ==============================================================================
# CP Agenda Pro — Environment Variables
# ==============================================================================
# INSTRUCTIONS:
#   1. Copy this file to: backend/.env
#   2. Fill in the values for your environment
#   3. NEVER commit the .env file — it is in .gitignore
#   4. The .env file MUST exist on the production server with correct values
# ==============================================================================

# --- Database (Required) ---
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=your_database_name
DB_USER=your_database_user
DB_PASS=your_database_password
DB_CHARSET=utf8mb4

# --- App ---
API_VERSION=1.0.0

# --- Security ---
# Set to 'false' in production — NEVER 'true' on a live server
DEBUG_MODE=false

# --- Telegram Bot ---
# Token from @BotFather. Required for push notifications.
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# --- Email (SMTP) ---
# Used for password reset emails
SMTP_HOST=smtp.your-provider.com
SMTP_PORT=587
SMTP_USER=your@email.com
SMTP_PASS=your_smtp_password
SMTP_FROM=noreply@creativeprintjp.com
